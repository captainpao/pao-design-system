{
  "name": "pao-design-system",
  "version": "0.1.0",
  "description": "Framework-agnostic Web Component design system (Lit)",
  "type": "module",
  "main": "./dist/pao-design-system.umd.js",
  "module": "./dist/pao-design-system.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/pao-design-system.js",
      "require": "./dist/pao-design-system.umd.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "tsc && vite build",
    "build-storybook": "storybook build",
    "lint": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.{ts,scss,md}\"",
    "prepare": "husky install"
  },
  "keywords": [
    "web-components",
    "lit",
    "design-system"
  ],
  "license": "MIT",
  "dependencies": {
    "lit": "^3.0.0"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^7.6.10",
    "@storybook/addon-links": "^7.6.10",
    "@storybook/blocks": "^7.6.10",
    "@storybook/web-components": "^7.6.10",
    "@storybook/web-components-vite": "^7.6.10",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "prettier": "^3.1.1",
    "sass": "^1.69.5",
    "storybook": "^7.6.10",
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "vite-plugin-dts": "^3.7.0"
  },
  "lint-staged": {
    "*.ts": "eslint --fix",
    "*.{ts,scss,md}": "prettier --write"
  }
}
