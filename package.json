{
  "name": "pao-design-system",
  "version": "0.1.0",
  "description": "Framework-agnostic Web Component design system (Lit)",
  "type": "module",
  "main": "./dist/pao-design-system.umd.js",
  "module": "./dist/pao-design-system.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/pao-design-system.js",
      "require": "./dist/pao-design-system.umd.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "tsc && vite build",
    "build-storybook": "storybook build",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.{ts,scss,md}\"",
    "prepare": "husky install"
  },
  "keywords": [
    "web-components",
    "lit",
    "design-system"
  ],
  "license": "MIT",
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.0.0",
    "@fortawesome/fontawesome-svg-core": "^7.0.0",
    "@fortawesome/free-brands-svg-icons": "^7.0.0",
    "@fortawesome/free-regular-svg-icons": "^7.0.0",
    "@fortawesome/free-solid-svg-icons": "^7.0.0",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-links": "^8.6.14",
    "@storybook/blocks": "^8.6.14",
    "lit": "^3.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/preset-env": "^7.28.3",
    "@open-wc/testing": "^4.0.0",
    "@storybook/web-components": "^8.6.14",
    "@storybook/web-components-vite": "^8.6.14",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@web/test-runner": "^0.18.0",
    "@web/test-runner-coverage-v8": "^0.8.0",
    "@web/test-runner-playwright": "^0.11.1",
    "babel-jest": "^30.1.2",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^8.0.3",
    "jest": "^30.1.3",
    "jest-environment-jsdom": "^30.1.2",
    "jest-util": "^30.2.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.1.1",
    "sass": "^1.69.5",
    "storybook": "^8.6.14",
    "ts-jest": "^29.4.4",
    "typescript": "^5.3.3",
    "vite": "^7.1.12",
    "vite-plugin-dts": "^4.5.4"
  },
  "lint-staged": {
    "*.ts": "eslint --fix",
    "*.{ts,scss,md}": "prettier --write"
  }
}
